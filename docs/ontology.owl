    </rdf:Description>
    


    <!-- https://edugate.cs.wright.edu/lod/ontology/currKG/Category -->


    <owl:Class rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Category">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://edugate.cs.wright.edu/lod/ontology/currKG/belongTo"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://edugate.cs.wright.edu/lod/ontology/currKG/Module"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://edugate.cs.wright.edu/lod/ontology/currKG/hasTitle"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <opla-sd:entityPosition rdf:nodeID="genid22"/>
        <rdfs:comment xml:lang="en">Represents a category is a high-level grouping used to organize modules (e.g., foundations, survey, methodology, standards).</rdfs:comment>
        <rdfs:label xml:lang="en">Category</rdfs:label>
        <currKG:isNativeTo rdf:resource="https://archive.org/services/purl/domain/modular_ontology_design_library/PartWhole"/>
    </owl:Class>
