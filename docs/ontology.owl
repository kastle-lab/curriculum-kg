        <rdfs:range rdf:resource="https://edugate.cs.wright.edu/lod/ontology/currKG/Level"/>
        <rdfs:comment xml:lang="en">Represents the relation of a module to its difficulty level.</rdfs:comment>
        <rdfs:label xml:lang="en">has level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://edugate.cs.wright.edu/lod/ontology/currKG/hasModule -->


