    <!-- https://edugate.cs.wright.edu/lod/ontology/currKG/asString -->


    <owl:DatatypeProperty rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/asString">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Event"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/LearningPath"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/LearningStep"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Persona"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/PersonaType"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Profession"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Topic"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provides a string lexicalization or label for a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">as string</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://edugate.cs.wright.edu/lod/ontology/currKG/hasMediaSourceLink -->


    <owl:DatatypeProperty rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/hasMediaSourceLink">
        <rdfs:domain rdf:resource="https://edugate.cs.wright.edu/lod/ontology/currKG/Media"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provides the source link or URL string for a media resource.</rdfs:comment>
        <rdfs:label xml:lang="en">has media source link</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://edugate.cs.wright.edu/lod/ontology/currKG/hasName -->


    <owl:DatatypeProperty rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/hasName">
        <rdfs:domain rdf:resource="https://edugate.cs.wright.edu/lod/ontology/currKG/Author"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provides a human-readable name string for a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">has name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://edugate.cs.wright.edu/lod/ontology/currKG/hasTitle -->


    <owl:DatatypeProperty rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/hasTitle">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Curriculum"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Media"/>
                    <rdf:Description rdf:about="https://edugate.cs.wright.edu/lod/ontology/currKG/Module"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provides a title string for a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">has title</rdfs:label>
    </owl:DatatypeProperty>
    


